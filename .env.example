# Azure AI / OpenAI
AZURE_AI_SERVICES_ENDPOINT=https://<your-ai-services>.services.ai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
OPENAI_API_VERSION=2024-12-01-preview

# Cosmos DB
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=lostnfound
COSMOS_CONTAINER=items

# Storage
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net
STORAGE_CONTAINER=images

# Managed Identity (for App Service — leave blank for local dev with az login)
AZURE_CLIENT_ID=

# Debug
DEBUG=true
